rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      // 누구나 읽기 가능
      allow read: if true;
      // 누구나 좋아요/댓글 등의 업데이트 가능
      allow update: if true;
      // 관리자만 새 게시물 생성 및 삭제 가능
      allow create, delete: if request.auth != null;
    }
    match /config/{document=**} {
      // 누구나 설정 정보 읽기 가능
      allow read: if true;
      // 관리자만 설정 정보 수정 가능
      allow write: if request.auth != null;
    }
    match /visits/{day} {
      // 관리자만 방문 통계 조회 가능 (게스트는 데이터 자체를 읽지 못함)
      allow read: if request.auth != null;
      // 누구나 카운트 시작 가능 (단, 1부터)
      allow create: if request.resource.data.count == 1;
      // 누구나 카운트 증가 가능 (단, +1씩만 허용 — 조작 방지)
      allow update: if request.resource.data.count == resource.data.count + 1;
      // 삭제 불가
      allow delete: if false;
    }
  }
}
